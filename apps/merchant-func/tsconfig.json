{
  "compilerOptions": {
    "module": "nodenext",
    "target": "es2022",
    "moduleResolution": "node16",
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "inlineSources": true
  },
  "exclude": [
    "__mocks__",
    "dist",
    "node_modules",
    "**/__tests__/*"
  ]
}

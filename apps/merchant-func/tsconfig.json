{
  "compilerOptions": {
    "target": "ES2022",
    "rootDir": ".",
    "outDir": "dist",
    "module": "ES2022",
    "moduleResolution": "node",
    "strict": true,
    "sourceMap": false,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
  },
  "exclude": [
    "__mocks__",
    "dist",
    "node_modules",
    "**/__tests__/*"
  ]
}
